NVIDIA_API_KEY=your-api-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot-webhook
WEBHOOK_PORT=21031

# GitHub webhook settings (optional) — enables push-to-restart via GitHub.
# The secret is used to verify webhook signatures (recommended).
# The path is the URL path for the webhook endpoint (default: /github-webhook).
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_WEBHOOK_PATH=/github-webhook

# Workspace directory for the agent's Docker sandbox (optional).
# Defaults to ~/coding-guy-workspace if not set.
WORKSPACE_DIR=/path/to/your/workspace

# API Key Pool Configuration
# Multiple API keys can be configured to enable key rotation and load balancing.
# Keys that hit rate limits are automatically cooled down.
# Methods (pick one):
# 1. Comma-separated list in NVIDIA_API_KEYS
# 2. Numbered keys: NVIDIA_API_KEY_0, NVIDIA_API_KEY_1, NVIDIA_API_KEY_2, etc.
# 3. Single key: NVIDIA_API_KEY (for backward compatibility)
NVIDIA_API_KEYS=key1,key2,key3
# Or use numbered keys:
# NVIDIA_API_KEY_0=your-first-api-key
# NVIDIA_API_KEY_1=your-second-api-key
# NVIDIA_API_KEY_2=your-third-api-key

# API Key cooldown duration in seconds after hitting rate limit (default: 60)
API_KEY_COOLDOWN=60

# Rate limiting configuration (all optional)
# Strategy: 'adaptive' (default), 'fixed', 'token_bucket', or 'none' to disable
RATE_LIMIT_STRATEGY=adaptive
# Initial delay between requests in seconds (default: 0.5)
RATE_LIMIT_INITIAL_DELAY=0.5
# Minimum delay for adaptive rate limiting (default: 0.1)
RATE_LIMIT_MIN_DELAY=0.1
# Maximum delay for adaptive rate limiting (default: 60.0)
RATE_LIMIT_MAX_DELAY=60.0

# Settings Database Configuration (optional)
# Path to SQLite database file for storing application settings
# If not set, defaults to ~/coding-guy-workspace/settings.db
CODING_GUY_SETTINGS_DB=/path/to/your/settings.db

# Git credentials (optional) — passed into the Docker sandbox
# so the agent can push/pull/clone and make commits.
GIT_TOKEN=your-git-token-here
GIT_USER_NAME=your-name
GIT_USER_EMAIL=your-email@example.com

# SSH cloning support (automatic — no configuration needed).
# When SSH_AUTH_SOCK is set, the agent forwards your SSH agent into the
# container for git clone over SSH. If ~/.ssh keys exist, they are
# mounted read-only. When SSH is unavailable, SSH URLs are automatically
# rewritten to HTTPS using GIT_TOKEN above.

# Slack Bot Integration (optional)
# To enable Slack support, create a Slack app at https://api.slack.com/apps
# Enable Socket Mode for persistent WebSocket connections (no public URL needed)
# Requires the following OAuth scopes: chat:write, im:history, app_mentions:read, commands, files:write
# Slash command: /coding-guy
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_SOCKET_MODE_TOKEN=xapp-your-app-level-token-here

# Suno API Integration (optional)
# To enable AI music generation via Suno, get your API key from:
# https://suno.com/api (or the official Suno API documentation)
# Once configured, the agent can generate songs with custom lyrics.
SUNO_API_KEY=your-suno-api-key-here
